# ─── Required ────────────────────────────────────────────────────────────────

# AI backend key
XAI_API_KEY=your_xai_api_key_here

# JWT secret — MUST be at least 32 characters
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# FIX-5: Fernet encryption key for PII fields at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=

# ─── OAuth Providers ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── URLs ────────────────────────────────────────────────────────────────────
# FIX-7: CORS — comma-separated list of allowed frontend origins (no wildcard)
FRONTEND_URL=https://legal.quanbyai.com
APP_URL=https://legal.quanbyai.com

# ─── Payment ─────────────────────────────────────────────────────────────────
GCASH_NUMBER=09XXXXXXXXX
BANK_NAME=BDO
BANK_ACCOUNT=XXXX-XXXX-XXXX
BANK_ACCOUNT_NAME=Quanby Solutions, Inc.

# ─── Optional ────────────────────────────────────────────────────────────────
APP_PORT=8080

# Set to "false" only for local HTTP development (never in production)
COOKIE_SECURE=true

# Admin secret for /api/admin/* endpoints (replace with proper RBAC in production)
ADMIN_SECRET=
